<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="PPNET_2.MainPage"
             Padding="20">

    <Grid RowDefinitions="Auto, Auto, *">
        <VerticalStackLayout Grid.Row="0" Spacing="10" Margin="0,0,0,10">
            <Label Text="Wyszukiwarka (Z API lub DB)" FontAttributes="Bold" FontSize="16" />
            <Entry Placeholder="Wpisz nazwę posiłku..." Text="{Binding SearchQuery}" />
            <HorizontalStackLayout Spacing="10">
                <Button Text="Dodaj z API" Command="{Binding SearchCommand}" />
                <Button Text="Ładuj wszystko z DB" Command="{Binding LoadFromDbCommand}" />
                <Button Text="Sortuj (A-Z)" Command="{Binding SortCommand}" />
            </HorizontalStackLayout>
            <BoxView HeightRequest="1" Color="Gray" Margin="0,10" />
            <Label Text="Dodaj posiłek ręcznie" FontAttributes="Bold" FontSize="16" />
            <Entry Placeholder="Nazwa posiłku..." Text="{Binding AddMealName}" />
            <Entry Placeholder="Kategoria..." Text="{Binding AddCategoryName}" />
            <Button Text="Dodaj" Command="{Binding AddManualCommand}" />
        </VerticalStackLayout>

        <Label Grid.Row="1" Text="Wyniki / Baza danych:" FontAttributes="Bold" FontSize="18" Margin="0,10,0,5" />

        <CollectionView Grid.Row="2" ItemsSource="{Binding Meals}">
            <CollectionView.ItemTemplate>
                <DataTemplate>
                    <Frame Margin="0,5" Padding="10" BorderColor="LightGray">
                        <Grid ColumnDefinitions="*, Auto">
                            <VerticalStackLayout Grid.Column="0">
                                <Label Text="{Binding Name}" FontAttributes="Bold" FontSize="16" />
                                <Label Text="{Binding Category.Name, StringFormat='Kategoria: {0}'}" FontSize="14" TextColor="Gray" />
                                <Label Text="{Binding Area, StringFormat='Obszar: {0}'}" FontSize="14" TextColor="Gray" />
                            </VerticalStackLayout>
                            
                            <Button Grid.Column="1" Text="Usuń" BackgroundColor="Red" TextColor="White" 
                                    Command="{Binding Source={RelativeSource AncestorType={x:Type ContentPage}}, Path=BindingContext.DeleteCommand}"
                                    CommandParameter="{Binding .}" />
                        </Grid>
                    </Frame>
                </DataTemplate>
            </CollectionView.ItemTemplate>
        </CollectionView>
    </Grid>

</ContentPage>
