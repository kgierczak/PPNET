@page "/sentiment"
@rendermode InteractiveServer
@using PPNET_4
@using Microsoft.Extensions.ML
@inject PredictionEnginePool<Sentiment_analysis_model.ModelInput, Sentiment_analysis_model.ModelOutput> PredictionPool

<PageTitle>Sentiment Analysis</PageTitle>

<h1>Sentiment Analysis</h1>

<p>Analyze the sentiment of your text using our ML model.</p>

<div class="mb-3">
    <label for="userInput" class="form-label">Enter your text:</label>
    <textarea class="form-control" id="userInput" rows="4" @bind="userInput" placeholder="Type something here..."></textarea>
</div>

<button class="btn btn-primary" @onclick="AnalyzeSentiment">Analyze Sentiment</button>

@if (prediction != null)
{
    <div class="mt-4">
        <h3>Results:</h3>
        <div class="alert alert-info">
            <p><strong>Predicted Sentiment:</strong> <span class="badge bg-primary">@prediction.PredictedLabel</span></p>
            @if (prediction.Score != null && prediction.Score.Length > 0)
            {
                <p><strong>Confidence:</strong> @(Math.Round(prediction.Score.Max() * 100, 2))%</p>
                <div class="mt-3">
                    <h5>Scores:</h5>
                    <ul class="list-group">
                        @foreach (var score in GetSortedScores(prediction))
                        {
                            <li class="list-group-item d-flex justify-content-between align-items-center">
                                @score.Key
                                <span class="badge bg-success">@(Math.Round(score.Value * 100, 2))%</span>
                            </li>
                        }
                    </ul>
                </div>
            }
        </div>
    </div>
}

@code {
    private string userInput = "";
    private Sentiment_analysis_model.ModelOutput? prediction;

    private void AnalyzeSentiment()
    {
        if (!string.IsNullOrWhiteSpace(userInput))
        {
            var input = new Sentiment_analysis_model.ModelInput { Text = userInput };
            prediction = PredictionPool.Predict(input);
        }
    }

    private List<KeyValuePair<string, float>> GetSortedScores(Sentiment_analysis_model.ModelOutput result)
    {
        if (result.Score == null)
            return new List<KeyValuePair<string, float>>();

        var scores = Sentiment_analysis_model.GetSortedScoresWithLabels(result).ToList();
        return scores;
    }
}
