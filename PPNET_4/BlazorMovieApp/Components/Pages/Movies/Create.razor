@page "/movies/create"
@using BlazorMovieApp.Data
@using Microsoft.AspNetCore.Authorization
@attribute [Authorize]
@rendermode InteractiveServer
@inject ApplicationDbContext DbContext
@inject NavigationManager NavigationManager

<PageTitle>Add New Movie</PageTitle>

<div class="container mt-4">
    <div class="row justify-content-center">
        <div class="col-md-6">
            <h1>🎬 Add New Movie</h1>

            <div class="card">
                <div class="card-body">
                    <div class="mb-3">
                        <label for="title" class="form-label">Title *</label>
                        <input type="text" id="title" class="form-control" 
                               @bind="movie.Title" placeholder="Enter movie title" />
                    </div>

                    <div class="mb-3">
                        <label for="description" class="form-label">Description</label>
                        <textarea id="description" class="form-control" rows="4"
                                  @bind="movie.Description" placeholder="Enter movie description"></textarea>
                    </div>

                    <div class="mb-3">
                        <label for="releaseDate" class="form-label">Release Date</label>
                        <input type="date" id="releaseDate" class="form-control"
                               @bind="movie.ReleaseDate" />
                    </div>

                    <div class="mb-3">
                        <label for="imageUrl" class="form-label">Image URL</label>
                        <input type="url" id="imageUrl" class="form-control"
                               @bind="movie.ImageUrl" placeholder="https://example.com/image.jpg" />
                        @if (!string.IsNullOrEmpty(movie.ImageUrl))
                        {
                            <div class="mt-2">
                                <small class="text-muted">Preview:</small>
                                <br />
                                <img src="@movie.ImageUrl" alt="Preview" class="img-fluid mt-2" style="max-height: 200px;" />
                            </div>
                        }
                    </div>

                    <div class="mb-3">
                        <label for="rate" class="form-label">Initial Rating (1-10)</label>
                        <input type="number" id="rate" class="form-control"
                               min="1" max="10" step="0.5"
                               @bind="movie.Rate" />
                    </div>

                    <div class="d-flex gap-2">
                        <button class="btn btn-primary" @onclick="SaveMovie">
                            <span class="bi bi-check-circle"></span> Save
                        </button>
                        <a href="/movies" class="btn btn-secondary">
                            <span class="bi bi-x-circle"></span> Cancel
                        </a>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

@code {
    private Movie movie = new Movie { Rate = 5 };

    private async Task SaveMovie()
    {
        if (string.IsNullOrWhiteSpace(movie.Title))
        {
            return;
        }

        try
        {
            if (movie.Rate.HasValue && movie.Rate > 0)
            {
                movie.AverageRate = movie.Rate;
                movie.RatingCount = 1;
            }

            DbContext.Movies.Add(movie);
            await DbContext.SaveChangesAsync();

            NavigationManager.NavigateTo("/movies");
        }
        catch (Exception ex)
        {
            Console.WriteLine($"Error saving movie: {ex.Message}");
        }
    }
}
