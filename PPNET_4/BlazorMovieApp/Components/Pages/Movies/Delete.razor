@page "/movies/delete/{Id:int}"
@using BlazorMovieApp.Data
@using Microsoft.AspNetCore.Authorization
@using Microsoft.EntityFrameworkCore
@attribute [Authorize]
@rendermode InteractiveServer
@inject ApplicationDbContext DbContext
@inject NavigationManager NavigationManager

<PageTitle>Delete Movie</PageTitle>

<div class="container mt-4">
    <div class="row justify-content-center">
        <div class="col-md-6">
            @if (movie == null)
            {
                <div class="alert alert-danger">
                    Movie not found.
                </div>
                <a href="/movies" class="btn btn-secondary">Back to Movies</a>
            }
            else
            {
                <div class="alert alert-warning" role="alert">
                    <h4 class="alert-heading">⚠️ Delete Movie</h4>
                    <p>Are you sure you want to delete <strong>@movie.Title</strong>?</p>
                    <hr>
                    <p class="mb-0">This action cannot be undone.</p>
                </div>

                <div class="card">
                    <div class="card-body">
                        <h5>@movie.Title</h5>
                        @if (!string.IsNullOrEmpty(movie.ImageUrl))
                        {
                            <img src="@movie.ImageUrl" alt="@movie.Title" class="img-fluid rounded mb-3" style="max-height: 300px;" />
                        }
                        <p class="text-muted">@(movie.Description ?? "No description")</p>

                        <div class="d-flex gap-2">
                            <button class="btn btn-danger" @onclick="DeleteMovie">
                                <span class="bi bi-trash"></span> Yes, Delete
                            </button>
                            <a href="/movies" class="btn btn-secondary">
                                <span class="bi bi-x-circle"></span> Cancel
                            </a>
                        </div>
                    </div>
                </div>
            }
        </div>
    </div>
</div>

@code {
    [Parameter]
    public int Id { get; set; }

    private Movie? movie;

    protected override async Task OnInitializedAsync()
    {
        try
        {
            movie = await DbContext.Movies.FirstOrDefaultAsync(m => m.Id == Id);
            if (movie == null)
            {
                NavigationManager.NavigateTo("/movies");
            }
        }
        catch (Exception ex)
        {
            Console.WriteLine($"Error loading movie: {ex.Message}");
        }
    }

    private async Task DeleteMovie()
    {
        if (movie == null)
        {
            return;
        }

        try
        {
            DbContext.Movies.Remove(movie);
            await DbContext.SaveChangesAsync();

            NavigationManager.NavigateTo("/movies");
        }
        catch (Exception ex)
        {
            Console.WriteLine($"Error deleting movie: {ex.Message}");
        }
    }
}
