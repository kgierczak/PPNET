@page "/weather"
@rendermode InteractiveServer

<PageTitle>Weather Forecast</PageTitle>

<div class="container mt-4">
    <h1>Weather Forecast</h1>
    
    <div class="alert alert-info" role="alert">
        <h4 class="alert-heading"><strong>Warm days (above 15ḞC): @warmDays</strong></h4>
    </div>

    <div class="mb-3">
        <button class="btn btn-primary me-2" @onclick="@(async () => await ColdDaysFilter(15))">
            <span class="bi bi-funnel"></span> Show Cold Days (&lt; 15ḞC)
        </button>
        <button class="btn btn-secondary" @onclick="@(async () => await Restore())">
            <span class="bi bi-arrow-clockwise"></span> Restore All
        </button>
    </div>

    <div class="mb-3">
        <input type="text" class="form-control" @oninput="@Input" placeholder="?? Search by weather description (e.g., Warm, Cold, Freezing)..." />
    </div>

    @if (forecasts == null)
    {
        <div class="text-center">
            <div class="spinner-border text-primary" role="status">
                <span class="visually-hidden">Loading...</span>
            </div>
            <p class="mt-2">Loading weather data...</p>
        </div>
    }
    else if (forecasts.Length == 0)
    {
        <div class="alert alert-warning">
            No weather data matches your filter. <button class="btn btn-link" @onclick="@(async () => await Restore())">Reset filters</button>
        </div>
    }
    else
    {
        <div class="table-responsive">
            <table class="table table-striped table-hover">
                <thead class="table-dark">
                    <tr>
                        <th>?? Date</th>
                        <th>??? Temp (C)</th>
                        <th>??? Temp (F)</th>
                        <th>?? Description</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var forecast in forecasts)
                    {
                        <tr>
                            <td>@forecast.Date.ToShortDateString()</td>
                            <td>
                                <span class="badge @(forecast.TemperatureC > 15 ? "bg-warning" : "bg-info")">
                                    @forecast.TemperatureCḞC
                                </span>
                            </td>
                            <td>
                                <span class="badge @(forecast.TemperatureC > 15 ? "bg-warning" : "bg-info")">
                                    @forecast.TemperatureFḞF
                                </span>
                            </td>
                            <td><strong>@forecast.Summary</strong></td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
        
        <div class="mt-3 text-muted">
            <small>Showing @forecasts.Length of @originalForecasts?.Length total forecasts | Warm days: @warmDays</small>
        </div>
    }
</div>

@code {
    private WeatherForecast[]? forecasts;
    private WeatherForecast[]? originalForecasts;
    private int warmDays = 0;

    protected override async Task OnInitializedAsync()
    {
        await Task.Delay(500);

        var startDate = DateOnly.FromDateTime(DateTime.Now);
        forecasts = Enumerable.Range(1, 10).Select(index =>
        {
            int tempC = Random.Shared.Next(-20, 55);
            string summary = GetWeatherSummary(tempC);

            return new WeatherForecast
            {
                Date = startDate.AddDays(index),
                TemperatureC = tempC,
                Summary = summary
            };
        }).ToArray();

        originalForecasts = forecasts.ToArray();
        warmDays = forecasts.Count(f => f.TemperatureC > 15);
    }

    private string GetWeatherSummary(int temperatureC)
    {
        return temperatureC switch
        {
            < 0 => "Freezing",
            >= 0 and < 5 => "Bracing",
            >= 5 and < 10 => "Chilly",
            >= 10 and < 15 => "Cool",
            >= 15 and < 20 => "Mild",
            >= 20 and < 25 => "Warm",
            >= 25 and < 30 => "Balmy",
            >= 30 and < 35 => "Hot",
            >= 35 and < 40 => "Sweltering",
            _ => "Scorching"
        };
    }

    private async Task ColdDaysFilter(int temperatureThreshold)
    {
        if (originalForecasts != null)
        {
            forecasts = originalForecasts.Where(f => f.TemperatureC < temperatureThreshold).ToArray();
            StateHasChanged();
        }
    }

    private async Task Restore()
    {
        if (originalForecasts != null)
        {
            forecasts = originalForecasts.ToArray();
            StateHasChanged();
        }
    }

    private async Task Input(ChangeEventArgs arg)
    {
        string? searchTerm = arg.Value?.ToString();

        if (string.IsNullOrEmpty(searchTerm))
        {
            await Restore();
        }
        else if (originalForecasts != null)
        {
            forecasts = originalForecasts.Where(f => f.Summary != null && f.Summary.Contains(searchTerm, StringComparison.OrdinalIgnoreCase)).ToArray();
            StateHasChanged();
        }
    }

    private class WeatherForecast
    {
        public DateOnly Date { get; set; }
        public int TemperatureC { get; set; }
        public string? Summary { get; set; }
        public int TemperatureF => 32 + (int)(TemperatureC / 0.5556);
    }
}
