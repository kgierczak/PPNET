<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="Lab_3.MainPage"
             Title="Image Filter Processor">

    <ScrollView>
        <VerticalStackLayout Padding="10" Spacing="10">

            <!-- Controls -->
            <HorizontalStackLayout Spacing="10" Margin="0,10">
                <Button x:Name="LoadImageBtn" Text="Load Image" Clicked="OnLoadImageClicked" HorizontalOptions="FillAndExpand"/>
                <Button x:Name="ProcessBtn" Text="Process" Clicked="OnProcessClicked" HorizontalOptions="FillAndExpand"/>
            </HorizontalStackLayout>

            <!-- Thread Count -->
            <HorizontalStackLayout Spacing="10" Margin="0,5" VerticalOptions="Start">
                <Label Text="Threads:" VerticalTextAlignment="Center"/>
                <Slider x:Name="ThreadSlider" Minimum="1" Maximum="8" Value="4" WidthRequest="200"/>
                <Label x:Name="ThreadCountLabel" Text="4" WidthRequest="40" VerticalTextAlignment="Center"/>
            </HorizontalStackLayout>

            <!-- Image Display -->
            <ScrollView HorizontalScrollBarVisibility="Always" VerticalScrollBarVisibility="Always" HeightRequest="400">
                <VerticalStackLayout Spacing="5">
                    <Label Text="Original Image" FontSize="16" FontAttributes="Bold"/>
                    <Image x:Name="OriginalImage" Aspect="AspectFit" HeightRequest="200"/>
                </VerticalStackLayout>
            </ScrollView>

            <!-- Results ScrollView -->
            <ScrollView HorizontalScrollBarVisibility="Always" VerticalScrollBarVisibility="Always">
                <VerticalStackLayout x:Name="ResultsContainer" Spacing="10" Padding="5"/>
            </ScrollView>

            <!-- Status -->
            <Label x:Name="StatusLabel" Text="Ready" FontSize="12" TextColor="Gray" Margin="0,10"/>
        </VerticalStackLayout>
    </ScrollView>

</ContentPage>
